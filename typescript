[48;2;42;45;68m  🚀 Quick Start                                                                                                                                          [49m
[48;2;42;45;68m  Python API                                                                                                                                              [49m
[48;2;42;45;68m                                                                                                                                                          [49m
[48;2;42;45;68m  sajepa can be trained completely from scratch on arbitrary 2D/3D scalar fields without requiring massive, pre-trained weights.                          [49m
[48;2;42;45;68m  Python                                                                                                                                                  [49m
[48;2;42;45;68m                                                                                                                                                          [49m
[48;2;42;45;68m  import torch                                                                                                                                            [49m
[48;2;42;45;68m  import numpy as np                                                                                                                                      [49m
[48;2;42;45;68m  from sajepa import ScaleAwareJEPA                                                                                                                       [49m
[48;2;42;45;68m                                                                                                                                                          [49m
[48;2;42;45;68m  # 1. Initialize your physical field (e.g., NGC 3627 molecular gas velocity map)                                                                         [49m
[48;2;42;45;68m  # Expected input shape: (H, W) or (C, H, W)                                                                                                             [49m
[48;2;42;45;68m  field_data = torch.load("data/ngc3627_co_emission.pt")                                                                                                  [49m
[48;2;42;45;68m                                                                                                                                                          [49m
[48;2;42;45;68m  # 2. Instantiate the Scale-Aware JEPA with an optional configuration file                                                                               [49m
[48;2;42;45;68m  model = ScaleAwareJEPA(config_path="configs/examples/mhd_2d_ms1p2.json")                                                                                [49m
[48;2;42;45;68m                                                                                                                                                          [49m
[48;2;42;45;68m  # 3. Fit the model and extract the pixel-registered latent atlas                                                                                        [49m
[48;2;42;45;68m  # This executes scale-specific masking interventions across epochs                                                                                      [49m
[48;2;42;45;68m  latent_atlas = model.fit_and_extract(field_data, epochs=10)                                                                                             [49m
[48;2;42;45;68m                                                                                                                                                          [49m
[48;2;42;45;68m  # The resulting coordinate tensor preserves your exact spatial resolution                                                                               [49m
[48;2;42;45;68m  print(f"Latent atlas shape: {latent_atlas.shape}") # (C_latent, H, W)                                                                                   [49m
[48;2;42;45;68m  np.save("outputs/latent_atlas.npy", latent_atlas.cpu().numpy())                                                                                         [49m
