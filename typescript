[48;2;42;45;68m  2. Code Example: TorchDR UMAP on Mac                                                                                                                    [49m
[48;2;42;45;68m  Unlike standard UMAP, torchdr.UMAP can keep everything on your preferred PyTorch device (like cpu or Apple Silicon's mps). It features a scikit-learn   [49m
[48;2;42;45;68m  compatible API (fit_transform).                                                                                                                         [49m
[48;2;42;45;68m                                                                                                                                                          [49m
[48;2;42;45;68m  Here is a complete workflow:                                                                                                                            [49m
[48;2;42;45;68m                                                                                                                                                          [49m
[48;2;42;45;68m  Python                                                                                                                                                  [49m
[48;2;42;45;68m  import torch                                                                                                                                            [49m
[48;2;42;45;68m  from torch.utils.data import TensorDataset, DataLoader                                                                                                  [49m
[48;2;42;45;68m  from torchdr import UMAP                                                                                                                                [49m
[48;2;42;45;68m  import matplotlib.pyplot as plt                                                                                                                         [49m
[48;2;42;45;68m                                                                                                                                                          [49m
[48;2;42;45;68m  # 1. Check for Apple Silicon GPU (MPS) or fallback to CPU                                                                                               [49m
[48;2;42;45;68m  device = "mps" if torch.backends.mps.is_available() else "cpu"                                                                                          [49m
[48;2;42;45;68m  print(f"Using device: {device}")                                                                                                                        [49m
[48;2;42;45;68m                                                                                                                                                          [49m
[48;2;42;45;68m  # 2. Setup dummy high-dimensional data directly as PyTorch Tensors                                                                                      [49m
[48;2;42;45;68m  X_data = torch.randn(1000, 50).to(device)  # 1000 samples, 50 features                                                                                  [49m
[48;2;42;45;68m  y_data = torch.randint(0, 3, (1000,)).to(device)                                                                                                        [49m
[48;2;42;45;68m                                                                                                                                                          [49m
[48;2;42;45;68m  # 3. Initialize TorchDR UMAP                                                                                                                            [49m
[48;2;42;45;68m  # You can explicitly set the device, or let it auto-detect from the input tensor                                                                        [49m
[48;2;42;45;68m  reducer = UMAP(n_neighbors=15, min_dist=0.1, device=device)                                                                                             [49m
[48;2;42;45;68m                                                                                                                                                          [49m
[48;2;42;45;68m  # 4. Fit and Transform                                                                                                                                  [49m
[48;2;42;45;68m  # The output 'embedding' will remain a PyTorch Tensor on the same device!                                                                               [49m
[48;2;42;45;68m  embedding = reducer.fit_transform(X_data)                                                                                                               [49m
[48;2;42;45;68m                                                                                                                                                          [49m
[48;2;42;45;68m  # 5. Move to CPU and convert to NumPy just for plotting                                                                                                 [49m
[48;2;42;45;68m  embedding_np = embedding.cpu().numpy()                                                                                                                  [49m
[48;2;42;45;68m  labels_np = y_data.cpu().numpy()                                                                                                                        [49m
[48;2;42;45;68m                                                                                                                                                          [49m
[48;2;42;45;68m  # 6. Visualize the output                                                                                                                               [49m
[48;2;42;45;68m  plt.figure(figsize=(8, 6))                                                                                                                              [49m
[48;2;42;45;68m  scatter = plt.scatter(embedding_np[:, 0], embedding_np[:, 1], c=labels_np, cmap='viridis', s=15)                                                        [49m
[48;2;42;45;68m  plt.colorbar(scatter)                                                                                                                                   [49m
[48;2;42;45;68m  plt.title('UMAP via TorchDR on macOS')                                                                                                                  [49m
[48;2;42;45;68m  plt.show()                                                                                                                                              [49m
[48;2;42;45;68m  3. Streaming Large PyTorch Datasets                                                                                                                     [49m
[48;2;42;45;68m  One of TorchDR’s best features is its ability to stream data out of a standard PyTorch DataLoader instead of requiring you to load the entire massive   [49m
[48;2;42;45;68m  tensor into memory at once.                                                                                                                             [49m
[48;2;42;45;68m                                                                                                                                                          [49m
[48;2;42;45;68m  If your dataset is too big for your Mac's unified memory, you can pass a DataLoader straight into the fit method:                                       [49m
[48;2;42;45;68m                                                                                                                                                          [49m
[48;2;42;45;68m  Python                                                                                                                                                  [49m
[48;2;42;45;68m  from torch.utils.data import DataLoader                                                                                                                 [49m
[48;2;42;45;68m                                                                                                                                                          [49m
[48;2;42;45;68m  # Create your loader                                                                                                                                    [49m
[48;2;42;45;68m  dataset = TensorDataset(X_data, y_data)                                                                                                                 [49m
[48;2;42;45;68m  dataloader = DataLoader(dataset, batch_size=256, shuffle=False)                                                                                         [49m
[48;2;42;45;68m                                                                                                                                                          [49m
[48;2;42;45;68m  # TorchDR can compute the UMAP embeddings using the loader                                                                                              [49m
[48;2;42;45;68m  # Note: Streaming via DataLoader typically requires installing the 'faiss' backend                                                                      [49m
[48;2;42;45;68m  reducer = UMAP(backend="faiss")                                                                                                                         [49m
[48;2;42;45;68m  embedding = reducer.fit_transform(dataloader)                                                                                                           [49m

