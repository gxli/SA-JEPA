{
  "data": {
    "data_root": "data",
    "npy_pattern": "C12_Beta20_256_0060-rho.npy_slice.npy_sm_0.5.npy",
    "num_samples": 200,
    "log_eps": 1e-06,
    "cdd_mode": "log",
    "cdd_constrained": true,
    "cdd_sm_mode": "reflect",
    "cube_slice_strategy": "center",
    "cube_slice_axis": 0,
    "cube_slice_index": 0,
    "random_roll_max": 0,
    "d4_augment": true
  },
  "model": {
    "mode": "pyramid",
    "model_key": "cdd_scaleaware_convnext",
    "sigmas": [2, 4, 8, 16],
    "latent_channels": 32,
    "encoder_width": 64,
    "encoder_depth": 4,
    "encoder_kernel_size": 7,
    "scaleaware_feat_channels": 8,
    "scaleaware_adapter_kernel_size": 3,
    "scaleaware_fusion_type": "topdown",
    "scaleaware_norm_per_scale": true,
    "scaleaware_final_norm": true,
    "scaleaware_stem_norm": true,
    "cdd_append_last_residual": true,
    "global_shift": false,
    "align_scales": true,
    "mask_box_size": 0,
    "post_log_transform": true,
    "cdd_log_std_floor_mult": 0.05,
    "ema_momentum": 0.996,
    "normalize_loss_l2": false,
    "predictor_layernorm": true,
    "predictor_residual": false,
    "mask_size_scaling": 1.0,
    "mask_spacing_scaling": 2.0,
    "target_invalid_region_skip": false,
    "patch_size": 3,
    "active_target_fraction": 1.0,
    "target_sampling_mode": "grid"
  },
  "train": {
    "batch_size": 4,
    "lr": 0.0001,
    "weight_decay": 1e-05,
    "num_workers": 4,
    "sigreg_weight": 10,
    "symmetric_feature_loss_weight": 0,
    "umap": {
      "metric": "euclidean",
      "standardize": true,
      "l2_normalize": false,
      "n_neighbors": 50,
      "min_dist": 0.2
    },
    "viz_crop_border": true,
    "compute_effective_rank": true,
    "ema_momentum_base": 0.996,
    "ema_momentum_final": 1.0
  }
}
