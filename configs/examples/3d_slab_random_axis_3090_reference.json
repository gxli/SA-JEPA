{
  "data": {
    "data_root": "data",
    "npy_pattern": "YOUR_3D_CUBE.npy",
    "input_type": "cube",
    "num_samples": 1000,
    "volume_crop_size": 128,
    "volume_random_axis": true,
    "volume_depth_axis": 0,
    "normalize": true,
    "crop_strategy": "random"
  },
  "model": {
    "mode": "3d_slab",
    "encoder_type": "cdd_scaleaware_convnext3d",
    "latent_channels": 16,
    "scale_channels": 8,
    "encoder_depth": 3,
    "encoder_kernel_size": 5,
    "encoder_stride": 1,
    "patch_size": 3,
    "slab_depth": 3,
    "num_targets": 32,
    "mask_size": 8,
    "num_mask_boxes": 8,
    "priority_candidate_oversample": 3.0,
    "normalize_loss_l2": true,
    "post_log_transform": true,
    "log_eps": 1e-6,
    "use_symmetric_feature_loss": false,
    "use_film": true,
    "use_per_scale_adapters": false,
    "ema_momentum": 0.996
  },
  "train": {
    "epochs": 50,
    "batch_size": 1,
    "lr": 1e-4,
    "min_lr": 1e-6,
    "warmup_epochs": 1,
    "weight_decay": 1e-5,
    "num_workers": 4,
    "prefetch_factor": 2,
    "log_interval": 1,
    "diagnostic_interval": 10,
    "prediction_loss_weight": 50,
    "vicreg_var_weight": 0,
    "vicreg_cov_weight": 0,
    "vicreg_spatial_mode": "pooled",
    "spread_regularizer": {
      "type": "std_hinge",
      "target": "context",
      "weight": 0,
      "target_std": 1.0,
      "eps": 0.0001
    },
    "symmetry_loss_weight": 0,
    "ema_momentum_base": 0.99,
    "ema_momentum_final": 0.999,
    "ema_warmup_fraction": 0.25,
    "movie_dump_every_epoch": true,
    "movie_dump_every_n_batches": 0,
    "movie_fixed_targets": false,
    "inference_num_samples": 1,
    "force_recompute_inference": true,
    "compute_effective_rank": true,
    "umap": {
      "metric": "euclidean",
      "standardize": true,
      "l2_normalize": false,
      "n_neighbors": 50,
      "min_dist": 0.2
    }
  },
  "notes": {
    "geometry": "For encoder_depth=3, encoder_kernel_size=5, patch_size=3, slab_depth=3, train.py auto-computes volume crop depth as encoder_rf_depth + slab_depth - 1 = 17 + 3 - 1 = 19. The loaded tensor is Bx1x19x128x128, the prediction/loss slab is BxCx3x128x128, and target z is fixed within that slab while y/x target placement follows the usual rejection budget.",
    "3090": "Start with volume_crop_size=128. Try 192 next on a clean 24GB RTX 3090. Use 256 only as an aggressive batch-1 run.",
    "axis": "volume_random_axis=true randomly chooses which source cube axis becomes the thin depth axis during training. Inference uses volume_depth_axis for stable outputs."
  }
}
