{
  "data": {
    "data_root": "data",
    "npy_pattern": "*.npy",
    "num_samples": 2000,
    "volume_crop_size": 64,
    "crop_strategy": "mixed",
    "log_transform": true,
    "log_eps": 1.0,
    "normalize": true,
    "cube_slice_strategy": "center",
    "cube_slice_axis": 0
  },
  "model": {
    "mode": "pyramid3d",
    "encoder_type": "cdd_scaleaware_convnext3d",
    "latent_channels": 32,
    "scale_channels": 32,
    "encoder_width": 32,
    "encoder_depth": 3,
    "encoder_kernel_size": 5,
    "encoder_stride": 1,
    "patch_size": 2,
    "num_targets": 64,
    "sigmas": [2, 4, 8, 16],
    "cell_sizes": [8, 16, 32, 64],
    "mask_fraction": 1.0,
    "mask_scaling_gaussian": 1.0,
    "normalize_loss": true,
    "gradient_checkpointing": true
  },
  "train": {
    "batch_size": 1,
    "epochs": 20,
    "lr": 0.0001,
    "weight_decay": 0.00001,
    "num_workers": 0,
    "momentum": 0.996,
    "force_recompute_inference": true,
    "inference_num_samples": 8,
    "amp": true,
    "jepa_loss_weight": 100.0,
    "vicreg_var_weight": 1.0,
    "vicreg_cov_weight": 0.1,
    "sigreg_weight": 0.0,
    "sharp_contrast_weight": 0.0,
    "umap": {
      "n_neighbors": 15,
      "min_dist": 0.05,
      "metric": "cosine",
      "random_state": 42,
      "init": "spectral",
      "l2_normalize": false,
      "standardize": false,
      "volumetric_sample_fraction": 0.05,
      "volumetric_max_points": 50000,
      "volumetric_sample_seed": 42
    }
  },
  "inference": {
    "default_mode": "slice2d",
    "enable_3d_volume": true,
    "slice_axis": 0,
    "slice_index": "center"
  }
}
