{
  "data": {
    "data_root": "data",
    "npy_pattern": "*.npy",
    "num_samples": 200,
    "image_size": 256,
    "log_transform": true,
    "log_eps": 1e-06,
    "cdd_scales": [2, 4, 8, 16],
    "cdd_strength": 1,
    "cdd_clip": true,
    "norm_before_cdd": true,
    "cdd_mode": "log",
    "cdd_constrained": true,
    "cdd_sm_mode": "reflect",
    "cube_slice_strategy": "auto",
    "cube_slice_axis": 0,
    "cube_slice_index": 0,
    "random_roll_max": 0,
    "cache_cdd": true,
    "cache_random_slices": true,
    "precompute_cdd_cache_all_slices": true,
    "d4_augment": true
  },
  "model": {
    "mode": "pyramid",
    "blur_mode": "cdd",
    "encoder_type": "cdd_scaleaware_convnext",
    "sigmas": [2, 4, 8, 16],
    "latent_channels": 32,
    "encoder_width": 64,
    "encoder_depth": 4,
    "encoder_kernel_size": 7,
    "scaleaware_feat_channels": 8,
    "scaleaware_adapter_kernel_size": 3,
    "mask_fraction": 1.0,
    "box_sigma_mult": 4,
    "mask_scale": 1.0,
    "min_mask_scale": 0,
    "spacing_scale": 2.0,
    "mask_size": 0.0,
    "full_grid": true,
    "global_shift": true,
    "align_scales": true,
    "constant_mask_box": false,
    "mask_box_size": 16,
    "cdd_mode": "log",
    "cdd_constrained": true,
    "cdd_sm_mode": "reflect",
    "mask_fill_mode": "gaussian_dip",
    "dip_sigma_mult": 1,
    "scaleaware_gaussian_ratios": [0.25, 0.5, 1.0, 2.0],
    "post_log_transform": true,
    "log_eps": 1e-06,
    "cdd_log_std_floor_mult": 0.05,
    "ema_momentum": 0.996,
    "normalize_loss": false,
    "predictor_layernorm": true,
    "mask_scaling_gaussian": 1,
    "mask_scaling_box": 1.0,
    "mask_spacing_scaling": 2.0
  },
  "train": {
    "batch_size": 8,
    "epochs": 10,
    "lr": 0.0001,
    "weight_decay": 1e-05,
    "num_workers": 0,
    "log_interval": 1,
    "jepa_loss_weight": 1,
    "vicreg_var_weight": 0,
    "vicreg_cov_weight": 0,
    "sigreg_weight": 0,
    "sigreg_sketch_dim": 64,
    "force_recompute_inference": true,
    "umap": {
      "n_neighbors": 30,
      "min_dist": 0.15,
      "metric": "cosine",
      "random_state": 42,
      "l2_normalize": true,
      "standardize": false
    },
    "viz_crop_border": true,
    "compute_effective_rank": true
  }
}
