{
  "model": {
    "latent_channels": 32,
    "patch_size": 16,
    "sigmas": [
      2,
      4,
      8,
      16
    ],
    "cell_sizes": [
      16,
      32,
      64,
      128
    ],
    "ema_momentum": 0.996,
    "normalize_loss": true,
    "blur_mode": "cdd",
    "cdd_mode": "log",
    "cdd_constrained": true,
    "cdd_sm_mode": "reflect",
    "align_scales": true,
    "full_grid": true,
    "global_shift": true,
    "constant_mask_box": false,
    "mask_scale": 2.0,
    "spacing_scale": 2.0,
    "mask_fraction": 1.0,
    "spacing_mult": 1.5,
    "box_sigma_mult": 4.0,
    "mask_box_size": 16,
    "mask_fill_mode": "gaussian_dip",
    "dip_sigma_mult": 1.0,
    "min_mask_scale": 4.0,
    "post_log_transform": true
  },
  "data": {
    "data_root": "data",
    "npy_pattern": "*.npy",
    "log_transform": true,
    "log_eps": 1.0,
    "cube_slice_strategy": "random",
    "cube_slice_axis": 0,
    "cube_slice_index": 0,
    "num_samples": 64,
    "image_size": 256,
    "use_cdd": true,
    "cdd_scales": [
      2,
      4,
      8
    ],
    "cdd_strength": 1.0,
    "cdd_clip": true,
    "norm_before_cdd": true,
    "cdd_mode": "log",
    "cdd_constrained": true,
    "cdd_sm_mode": "reflect"
  },
  "train": {
    "epochs": 1,
    "batch_size": 4,
    "num_workers": 0,
    "lr": 0.0001,
    "weight_decay": 1e-05,
    "momentum": 0.996,
    "log_interval": 1
  },
  "loss": {
    "weight_jepa": 1.0,
    "weight_pixel": 0.0
  }
}