{
  "data": {
    "data_root": "data",
    "npy_pattern": "*.npy",
    "num_samples": 200,
    "image_size": 256,
    "log_transform": true,
    "log_eps": 1e-06,
    "cdd_scales": [
      2,
      4,
      8,
      16
    ],
    "cdd_strength": 1,
    "cdd_clip": true,
    "norm_before_cdd": true,
    "cdd_mode": "log",
    "cdd_constrained": true,
    "cdd_sm_mode": "reflect",
    "cube_slice_strategy": "auto",
    "cube_slice_axis": 0,
    "cube_slice_index": 0,
    "random_roll_max": 0,
    "cache_cdd": true,
    "cache_random_slices": true,
    "precompute_cdd_cache_all_slices": true,
    "d4_augment": true
  },
  "model": {
    "latent_channels": 32,
    "predictor_hidden": 128,
    "patch_size": 2,
    "sigmas": [
      2,
      4,
      8,
      16
    ],
    "cell_sizes": [
      16,
      32,
      64,
      128
    ],
    "mask_fraction": 1.0,
    "box_sigma_mult": 4,
    "mask_scale": 1.0,
    "min_mask_scale": 0,
    "spacing_scale": 2.0,
    "full_grid": true,
    "global_shift": true,
    "align_scales": true,
    "constant_mask_box": true,
    "mask_box_size": 16,
    "blur_mode": "cdd",
    "cdd_mode": "log",
    "cdd_constrained": true,
    "cdd_sm_mode": "reflect",
    "mask_fill_mode": "zero",
    "dip_sigma_mult": 1.0,
    "post_log_transform": true,
    "log_eps": 1e-06,
    "cdd_log_std_floor_mult": 0.05,
    "ema_momentum": 0.996,
    "normalize_loss": true,
    "predictor_layernorm": true,
    "encoder_type": "cdd_opnet",
    "encoder_width": 32,
    "encoder_depth": 4,
    "encoder_kernel_size": 3,
    "mode": "pyramid",
    "mfae_scales": [
      1,
      2,
      4
    ],
    "mfae_features": [
      "x",
      "gradmag",
      "abslap",
      "local_std"
    ],
    "mfae_normalize_attributes": false,
    "mask_scaling_gaussian": 1.0,
    "mask_size": 0.0,
    "mask_scaling_box": 1.0,
    "mask_spacing_scaling": 2.0,
    "opnet_dilation_mode": "half_cdd_scale",
    "opnet_max_dilation": 8,
    "op_smoothing_mode": "sqrt_scale",
    "op_smoothing_mult": 1.0,
    "op_smoothing_padding_mode": "reflect",
    "opnet_channel_mode": "multi",
    "opnet_cache_primitives": true,
    "opnet_cache_detach": true
  },
  "train": {
    "batch_size": 8,
    "epochs": 10,
    "lr": 0.0001,
    "weight_decay": 1e-05,
    "num_workers": 0,
    "log_interval": 1,
    "save_blurred_images": true,
    "save_blurred_images_max": 8,
    "jepa_loss_weight": 1,
    "vicreg_var_weight": 0,
    "vicreg_cov_weight": 0,
    "sigreg_weight": 0,
    "sigreg_sketch_dim": 64,
    "force_recompute_inference": true,
    "umap": {
      "n_neighbors": 30,
      "min_dist": 0.15,
      "metric": "cosine",
      "random_state": 42,
      "l2_normalize": true,
      "standardize": false
    },
    "viz_l2_normalize": true,
    "viz_crop_border": true,
    "compute_effective_rank": true
  }
}
