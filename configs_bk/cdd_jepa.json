{
  "data": {
    "data_root": "data",
    "npy_pattern": "*.npy",
    "num_samples": 64,
    "image_size": 256,
    "log_transform": true,
    "log_eps": 1.0,
    "cdd_scales": [2, 4, 8, 16],
    "cdd_strength": 1.0,
    "cdd_clip": true,
    "norm_before_cdd": true,
    "cdd_mode": "log",
    "cdd_constrained": true,
    "cdd_sm_mode": "reflect",
    "cube_slice_strategy": "random",
    "cube_slice_axis": 0,
    "cube_slice_index": 0
  },
  "model": {
    "blur_mode": "cdd",
    "latent_channels": 32,
    "predictor_hidden": 64,
    "patch_size": 2,
    "sigmas": [2, 4, 8, 16],
    "max_targets_per_image": 16,
    "mask_fraction": 0.2,
    "mask_fill_mode": "zero",
    "mask_box_size": 16,
    "constant_mask_box": true,
    "align_scales": true,
    "full_grid": true,
    "global_shift": true,
    "spacing_scale": 2.0,
    "post_log_transform": true,
    "log_eps": 1.0,
    "ema_momentum": 0.996,
    "normalize_loss": true
  },
  "train": {
    "batch_size": 2,
    "num_workers": 0,
    "epochs": 1,
    "lr": 0.0001,
    "weight_decay": 0.00001,
    "log_interval": 1,
    "momentum": 0.996
  },
  "loss": {
    "weight_jepa": 1.0,
    "weight_pixel": 0.0
  }
}
