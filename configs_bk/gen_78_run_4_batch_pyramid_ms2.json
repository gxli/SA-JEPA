{
  "base_config": "../base_pyramid_scaleaware_convnext.json",
  "data": {
    "npy_pattern": "random_projection_ensemble.npy",
    "log_transform": false,
    "input_type": "image_batch",
    "image_batch_n_sample": "full",
    "cube_slice_strategy": "center",
    "d4_augment": false
  },
  "model": {
    "mode": "pyramid",
    "model_key": "cdd_scaleaware_convnext",
    "post_log_transform": false,
    "predictor_layernorm": false,
    "predictor_spatial_conv": false,
    "mask_box_size": 0,
    "mask_size_scaling": 2.0,
    "target_sampling_mode": "grid",
    "global_shift": false,
    "align_scales": true
  },
  "train": {
    "epochs": 10,
    "log_interval": 1,
    "mse_loss_weight": 100.0,
    "vicreg_var_weight": 0.0,
    "vicreg_cov_weight": 0.0,
    "sigreg_weight": 1.0,
    "sigreg_sketch_dim": 64
  }
}
