{
  "data": {
    "data_root": "data",
    "npy_pattern": "*.npy",
    "num_samples": 200,
    "image_size": 256,
    "log_transform": true,
    "log_eps": 1e-06,
    "cdd_scales": [
      2,
      4,
      8,
      16
    ],
    "cdd_strength": 1.0,
    "cdd_clip": true,
    "norm_before_cdd": true,
    "cdd_mode": "log",
    "cdd_constrained": true,
    "cdd_sm_mode": "reflect",
    "cube_slice_strategy": "random",
    "cube_slice_axis": 0,
    "cube_slice_index": 0
  },
  "model": {
    "latent_channels": 64,
    "predictor_hidden": 128,
    "patch_size": 2,
    "sigmas": [
      2,
      4,
      8,
      16
    ],
    "cell_sizes": [
      16,
      32,
      64,
      128
    ],
    "mask_fraction": 0.2,
    "spacing_mult": 1.5,
    "box_sigma_mult": 4.0,
    "mask_scale": 1.0,
    "min_mask_scale": 0.0,
    "spacing_scale": 2.0,
    "full_grid": true,
    "global_shift": true,
    "align_scales": true,
    "constant_mask_box": false,
    "mask_box_size": 16,
    "blur_mode": "gaussian",
    "cdd_mode": "log",
    "cdd_constrained": true,
    "cdd_sm_mode": "reflect",
    "mask_fill_mode": "gaussian_dip",
    "dip_sigma_mult": 0.9,
    "post_log_transform": true,
    "log_eps": 1e-06,
    "cdd_log_std_floor_mult": 0.05,
    "ema_momentum": 0.996,
    "normalize_loss": true
  },
  "train": {
    "batch_size": 8,
    "epochs": 10,
    "lr": 0.0001,
    "weight_decay": 1e-05,
    "num_workers": 0,
    "log_interval": 1,
    "save_blurred_images": true,
    "save_blurred_images_max": 8,
    "jepa_loss_weight": 100.0,
    "vicreg_var_weight": 1.0,
    "vicreg_cov_weight": 0.1
  }
}
