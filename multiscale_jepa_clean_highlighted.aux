\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {CDD-scale-aware JEPA architecture.} The CDD frontend decomposes the raw physical field into scale-separated components. The context branch applies scale-aware masking and encodes the masked context with a CDD-scale-aware encoder. The target branch bypasses masking and uses an EMA-updated copy of the encoder to provide target latent representations. A lightweight predictor maps the context representation to the target latent space. Training combines latent prediction, a weak context spread regularizer, and weak symmetry consistency. At inference, masking is disabled and the encoder produces dense latent maps for structural analysis.}}{3}{figure.1}\protected@file@percent }
\newlabel{fig:framework}{{1}{3}{\textbf {CDD-scale-aware JEPA architecture.} The CDD frontend decomposes the raw physical field into scale-separated components. The context branch applies scale-aware masking and encodes the masked context with a CDD-scale-aware encoder. The target branch bypasses masking and uses an EMA-updated copy of the encoder to provide target latent representations. A lightweight predictor maps the context representation to the target latent space. Training combines latent prediction, a weak context spread regularizer, and weak symmetry consistency. At inference, masking is disabled and the encoder produces dense latent maps for structural analysis}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces  \textbf  {CDD decomposition and pyramid masking.} \textit  {Left:} Constrained Diffusion Decomposition applied to a physical field, yielding a stack of dense, pixel-registered scale layers ordered from fine (top) to coarse (bottom). Each layer isolates coherent structures at a distinct physical scale — fine filaments and compact cores at small scales, extended morphology and large-scale envelopes at coarser scales — without spectral leakage between levels. \textit  {Right:} Scale-aware pyramid masking applied to the CDD stack. At each scale level, a spatially contiguous block is masked, with the masked region growing proportionally with scale. This forces the JEPA predictor to infer fine-scale structural targets from macroscopic context, calibrating the predictive bottleneck along the true physical hierarchy of the field rather than at an arbitrary fixed resolution. }}{4}{figure.2}\protected@file@percent }
\newlabel{fig:masking_demo}{{2}{4}{\textbf {CDD decomposition and pyramid masking.} \textit {Left:} Constrained Diffusion Decomposition applied to a physical field, yielding a stack of dense, pixel-registered scale layers ordered from fine (top) to coarse (bottom). Each layer isolates coherent structures at a distinct physical scale — fine filaments and compact cores at small scales, extended morphology and large-scale envelopes at coarser scales — without spectral leakage between levels. \textit {Right:} Scale-aware pyramid masking applied to the CDD stack. At each scale level, a spatially contiguous block is masked, with the masked region growing proportionally with scale. This forces the JEPA predictor to infer fine-scale structural targets from macroscopic context, calibrating the predictive bottleneck along the true physical hierarchy of the field rather than at an arbitrary fixed resolution}{figure.2}{}}
