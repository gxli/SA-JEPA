\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Scale-aware ConvNeXt encoder.} The input field $x$ is first decomposed into a CDD pyramid of pixel-registered scale components. The encoder then processes each CDD component along a per-scale adapter path before cross-scale fusion, preserving scale identity before spatial mixing. The fused multiscale representation is passed through a dense ConvNeXt encoder to produce the full-resolution latent map $z_c$.}}{11}{figure.6}\protected@file@percent }
\newlabel{fig:cdd_scaleaware_convnext_encoder}{{6}{11}{\textbf {Scale-aware ConvNeXt encoder.} The input field $x$ is first decomposed into a CDD pyramid of pixel-registered scale components. The encoder then processes each CDD component along a per-scale adapter path before cross-scale fusion, preserving scale identity before spatial mixing. The fused multiscale representation is passed through a dense ConvNeXt encoder to produce the full-resolution latent map $z_c$}{figure.6}{}}
