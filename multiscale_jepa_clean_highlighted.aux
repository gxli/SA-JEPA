\@writefile{toc}{\contentsline {section}{\numberline {}Multiscale-JEPA on MHD Turbulence}{5}{section*.10}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Dense latent topology learned for MHD turbulence.} Target-encoder embeddings are projected to three dimensions using PCA and UMAP and mapped back to their original spatial locations. The PCA projection provides a linear view of the dominant latent directions, while the UMAP projection emphasizes nonlinear neighborhood structure in the learned representation. Both projections reveal spatially coherent organization: extended sheets, filamentary interfaces, and compact high-contrast structures occupy distinct regions of latent space. The inset point clouds show the corresponding three-dimensional projected latent distributions.}}{6}{figure.3}\protected@file@percent }
\newlabel{fig:jepa_mhd}{{3}{6}{\textbf {Dense latent topology learned for MHD turbulence.} Target-encoder embeddings are projected to three dimensions using PCA and UMAP and mapped back to their original spatial locations. The PCA projection provides a linear view of the dominant latent directions, while the UMAP projection emphasizes nonlinear neighborhood structure in the learned representation. Both projections reveal spatially coherent organization: extended sheets, filamentary interfaces, and compact high-contrast structures occupy distinct regions of latent space. The inset point clouds show the corresponding three-dimensional projected latent distributions}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Dense latent topology learned for the NGC molecular-gas field.} Target-encoder embeddings are projected with PCA and UMAP and back-mapped to the observed field. The PCA projection highlights large-scale latent variation across spiral-arm and interarm morphology, while the UMAP projection separates nonlinear structural neighborhoods associated with bright molecular complexes, diffuse emission, and elongated arm-like features. The inset point clouds show the projected latent geometry, indicating that the representation forms a continuous but structured manifold rather than a set of discrete supervised classes.}}{7}{figure.4}\protected@file@percent }
\newlabel{fig:jepa_ngc}{{4}{7}{\textbf {Dense latent topology learned for the NGC molecular-gas field.} Target-encoder embeddings are projected with PCA and UMAP and back-mapped to the observed field. The PCA projection highlights large-scale latent variation across spiral-arm and interarm morphology, while the UMAP projection separates nonlinear structural neighborhoods associated with bright molecular complexes, diffuse emission, and elongated arm-like features. The inset point clouds show the projected latent geometry, indicating that the representation forms a continuous but structured manifold rather than a set of discrete supervised classes}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Dense latent topology learned for the Chengdu nighttime-light field.} Target-encoder embeddings are projected with PCA and UMAP and mapped back to their original spatial locations. The projections reveal coherent latent organization across the urban field, separating compact high-intensity cores, extended road-like structures, diffuse emission, and low-intensity surrounding regions. The inset shows the original nighttime-light image, providing the spatial reference for the latent back-mapping.}}{8}{figure.5}\protected@file@percent }
\newlabel{fig:jepa_chengdu}{{5}{8}{\textbf {Dense latent topology learned for the Chengdu nighttime-light field.} Target-encoder embeddings are projected with PCA and UMAP and mapped back to their original spatial locations. The projections reveal coherent latent organization across the urban field, separating compact high-intensity cores, extended road-like structures, diffuse emission, and low-intensity surrounding regions. The inset shows the original nighttime-light image, providing the spatial reference for the latent back-mapping}{figure.5}{}}
